# Required
DISCORD_TOKEN=your-discord-bot-token-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional — comma-separated Discord user IDs that can interact with Bridgette
# If not set, anyone in the server can talk to her
ALLOWED_USER_IDS=123456789012345678,987654321098765432

# Optional — channel ID where Bridgette logs activity (future use)
LOG_CHANNEL_ID=your-log-channel-id-here
